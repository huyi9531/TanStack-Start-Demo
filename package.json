{
  "name": "tanstack-start-cloudflare-demo",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "validate": "npm run check && npm run typecheck && npm run lint && npm test && npm run build",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-start": "1.168.27",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.4",
    "@tailwindcss/vite": "4.3.2",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-config": "0.4.0",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.18",
    "@types/node": "22.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "prettier": "3.9.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9",
    "wrangler": "4.106.0"
  }
}
